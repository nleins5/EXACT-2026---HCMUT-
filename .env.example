# ────────────────────────────────────────────────────────────────────
# EXACT-2026 Environment Configuration
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────────

# LangSmith tracing (optional — for debugging pipeline runs)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=exact-2026

# Closed-source LLM APIs are prohibited. Do not configure GPT/Claude/Gemini keys.

# Request budget override (seconds). Q&A Q13 hard cap is 60s/request.
EXACT_REQUEST_BUDGET_SECONDS=58
